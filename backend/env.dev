# 开发环境配置文件
# 复制此文件为 .env 用于本地开发

# ===== 必须配置的项目 =====
# Redis 配置 - 开发环境（本地Redis或开发服务器）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=1

# ===== 开发环境特定配置 =====
# 基础配置
PORT=8080
GIN_MODE=debug
HOST=0.0.0.0

# Redis 连接池配置（开发环境较小）
REDIS_POOL_SIZE=5
REDIS_MIN_IDLE=2

# 验证码配置（开发环境宽松一些）
CAPTCHA_EXPIRE_TIME=10m
CAPTCHA_MAX_ATTEMPTS=10
CAPTCHA_IP_RATE_LIMIT=50

# 日志配置（开发环境详细日志）
LOG_LEVEL=debug
LOG_FORMAT=text

# 安全配置（开发环境宽松）
ENABLE_RATE_LIMIT=false
RATE_LIMIT_REQUESTS=1000
TRUSTED_PROXIES=127.0.0.1,::1

# 监控配置
ENABLE_METRICS=true