    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/crypto-js": "4.2.2",
    "@types/react": "19.0.1",
    "@types/react-dom": "19.0.1",
    "@umijs/fabric": "4.0.1",
    "dumi": "2.4.17",
    "father": "4.5.1",
    "gh-pages": "6.2.0",
    "husky": "9.1.7",
    "lint-staged": "15.2.11",
    "prettier": "3.4.2",
    "yorkie": "2.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
